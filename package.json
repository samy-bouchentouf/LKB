{
  "name": "lkb",
  "version": "1.0.0",
  "description": "Knowledge management platform and AI assistant for the Kastler Brossel Laboratory",
  "type": "module",
  "main": "backend/server.js",
  "scripts": {
    "backend": "node backend/server.js",
    "chatbot": "uvicorn chatbot.engine.api:app --reload --port 8000",
    "dev": "concurrently -n CHATBOT,BACKEND -c blue,green \"npm run chatbot\" \"npm run backend\"",
    "start": "npm run dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samy-bouchentouf/LKB.git"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dompurify": "^3.4.12",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "marked": "^18.0.6",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
